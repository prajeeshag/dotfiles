[
    {
        "clean": [
            "~",
            "~/bin/"
        ]
    },
    {
        "shell": [
            ["mkdir -p ~/.vim/autoload/ ~/bin/ ", "Creating dirs."]
        ]
    },
    {
        "link": {
            "~/.vimrc":"vimrc"
        }
    },
    {
        "shell": [
            ["git submodule update --init --recursive", "Installing/updating submodules"]
        ]
    },
    {
        "link": {
            "~/.vim/autoload/plug.vim":"vim-plug/plug.vim"
        }
    }
]
